# Stack AI API configuration
STACKAI_API_BASE_URL=https://api.stack-ai.com
STACKAI_AUTH_BASE_URL=https://sb.stack-ai.com

# Auth strategy 1 (recommended): access token
STACKAI_ACCESS_TOKEN=

# Auth strategy 2: email/password login against Supabase auth
STACKAI_EMAIL=
STACKAI_PASSWORD=
# Required for email/password auth strategy (see notebook setup)
STACKAI_AUTH_ANON_KEY=

# Required Stack AI connection target
STACKAI_CONNECTION_ID=

# Required for hidden-state persistence and server-side unlist/restore
DATABASE_URL=

# Optional for browse-only mode, required for status overlay and index/deindex actions
STACKAI_KNOWLEDGE_BASE_ID=

# Optional API route rate limit (requests per IP per minute)
# API_RATE_LIMIT_MAX_REQUESTS=120
# Optional backend selection for API rate limiting: off | memory | upstash
# In production, default auto-mode uses Upstash if configured, otherwise disables rate limiting.
# Set memory explicitly only if per-instance fallback is acceptable.
# API_RATE_LIMIT_BACKEND=upstash
